#!/bin/sh
# .githooks/pre-commit — Git pre-commit hook
# Checkpoint SQLite WAL before commit to prevent data loss
# Works on Windows (Git Bash), macOS, Linux
#
# Called automatically by git before each commit.
# Errors do NOT block the commit (exit 0 always).

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null)
CHECKPOINT_SCRIPT="$REPO_ROOT/scripts/checkpoint-db.cjs"

if [ -f "$CHECKPOINT_SCRIPT" ]; then
    node "$CHECKPOINT_SCRIPT" 2>/dev/null || true
fi

exit 0
